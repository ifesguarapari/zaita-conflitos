[node name="Description" type="Label" parent="Card/Margin/Content/Body/RightColumn/TextPanel/TextMargin"]
theme_override_colors/font_color = Color(0.94, 0.92, 0.86, 1)
theme_override_font_sizes/font_size = 17
text = "Zaíta e Naíta procuram uma figurinha-flor perdida enquanto o irmão tenta protegê-las do perigo que cresce nos becos. Clique no chão para mover o irmão, toque nos inimigos para mirar e use as caveiras negras para trocar de arma ou colocar escudos e torretas na borda segura. Mantenha as irmãs longe dos tiros. A pistola é gratuita; escopeta, metralhadora e defesas dependem das caveiras conquistadas ao derrotar inimigos."
horizontal_alignment = 0
vertical_alignment = 0
autowrap_mode = 3

